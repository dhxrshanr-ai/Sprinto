# ─── Server / Backend ────────────────────────────────────────────────────────
# MongoDB connection string (use Atlas URI in production)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/taskflow

# JWT secret – use a long random string (min 32 chars) in production
JWT_SECRET=your_super_secret_jwt_key_replace_this_in_production

# Server port
PORT=5000

# Node environment (development | production | test)
NODE_ENV=development

# Frontend origin for CORS (comma-separated if multiple)
CLIENT_URL=http://localhost:3000

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Only if you override the vite proxy in production
# VITE_API_URL=https://your-backend.render.com/api

# ─── Optional: Monitoring ────────────────────────────────────────────────────
# PROMETHEUS_PORT=9090
